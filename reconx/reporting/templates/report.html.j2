<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; style-src 'unsafe-inline'; script-src 'none';">
    <title>ReconX Report — {{ target }}</title>
    <style>
        :root {
            --bg: #0d1117;
            --surface: #161b22;
            --border: #30363d;
            --text: #e6edf3;
            --text-dim: #8b949e;
            --accent: #58a6ff;
            --green: #3fb950;
            --yellow: #d29922;
            --orange: #db6d28;
            --red: #f85149;
            --purple: #bc8cff;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
            background: var(--bg); color: var(--text); line-height: 1.6;
            padding: 2rem; max-width: 1200px; margin: 0 auto;
        }
        h1 { color: var(--accent); margin-bottom: 0.5rem; font-size: 1.8rem; }
        h2 { color: var(--text); margin: 2rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
        h3 { color: var(--text-dim); margin: 1.5rem 0 0.5rem; }
        .meta { color: var(--text-dim); margin-bottom: 2rem; font-size: 0.9rem; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin: 1rem 0; }
        .card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; padding: 1rem; text-align: center;
        }
        .card .value { font-size: 2rem; font-weight: bold; color: var(--accent); }
        .card .label { font-size: 0.8rem; color: var(--text-dim); text-transform: uppercase; }
        table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        th {
            background: var(--surface); color: var(--accent); text-align: left;
            padding: 0.75rem; border-bottom: 2px solid var(--border); font-size: 0.85rem;
            text-transform: uppercase; letter-spacing: 0.05em;
        }
        td { padding: 0.75rem; border-bottom: 1px solid var(--border); font-size: 0.9rem; }
        tr:hover td { background: rgba(88, 166, 255, 0.05); }
        .severity-critical { color: var(--red); font-weight: bold; }
        .severity-high { color: var(--orange); font-weight: bold; }
        .severity-medium { color: var(--yellow); }
        .severity-low { color: var(--green); }
        .severity-info { color: var(--text-dim); }
        .score { font-weight: bold; font-size: 1.1rem; }
        .score-high { color: var(--red); }
        .score-medium { color: var(--yellow); }
        .score-low { color: var(--green); }
        .tag {
            display: inline-block; padding: 0.15rem 0.5rem; border-radius: 4px;
            font-size: 0.75rem; margin: 0.1rem; background: rgba(88, 166, 255, 0.15); color: var(--accent);
        }
        code { background: var(--surface); padding: 0.15rem 0.4rem; border-radius: 3px; font-size: 0.85rem; }
        .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--text-dim); font-size: 0.8rem; }
    </style>
</head>
<body>
    <h1>🔍 ReconX Report</h1>
    <p class="meta">Target: <strong>{{ target }}</strong> | Scan #{{ scan_id }} | {{ generated_at }}</p>

    <h2>📊 Summary</h2>
    <div class="grid">
        <div class="card">
            <div class="value">{{ summary.get('subdomains', 0) }}</div>
            <div class="label">Subdomains</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('hosts', 0) }}</div>
            <div class="label">Live Hosts</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('ports', 0) }}</div>
            <div class="label">Open Ports</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('urls', 0) }}</div>
            <div class="label">URLs</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('js_files', 0) }}</div>
            <div class="label">JS Files</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('js_findings', 0) }}</div>
            <div class="label">Secrets</div>
        </div>
        <div class="card">
            <div class="value">{{ severity_counts.get('critical', 0) + severity_counts.get('high', 0) }}</div>
            <div class="label">Critical+High</div>
        </div>
        <div class="card">
            <div class="value">{{ summary.get('findings', 0) }}</div>
            <div class="label">Total Findings</div>
        </div>
    </div>

    {% if profiles %}
    <h2>🎯 Top Risk-Scored Assets</h2>
    <table>
        <thead>
            <tr><th>Score</th><th>Host</th><th>Technologies</th><th>Reasons</th></tr>
        </thead>
        <tbody>
            {% for p in profiles[:20] %}
            <tr>
                <td>
                    <span class="score {% if p.risk_score >= 75 %}score-high{% elif p.risk_score >= 50 %}score-medium{% else %}score-low{% endif %}">
                        {{ p.risk_score }}
                    </span>
                </td>
                <td>{{ p.host }}</td>
                <td>{% for t in p.technologies[:5] %}<span class="tag">{{ t }}</span>{% endfor %}</td>
                <td>{% for r in p.reasons[:3] %}<div>{{ r }}</div>{% endfor %}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if findings %}
    <h2>🔴 Vulnerability Findings</h2>
    <table>
        <thead>
            <tr><th>Severity</th><th>Template</th><th>Host</th><th>Description</th></tr>
        </thead>
        <tbody>
            {% for f in findings %}
            <tr>
                <td><span class="severity-{{ f.severity }}">{{ f.severity | upper }}</span></td>
                <td><code>{{ f.template }}</code></td>
                <td>{{ f.host }}</td>
                <td>{{ f.description or '—' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if hosts %}
    <h2>🌐 Live Hosts</h2>
    <table>
        <thead>
            <tr><th>URL</th><th>Status</th><th>Title</th><th>IP</th></tr>
        </thead>
        <tbody>
            {% for h in hosts %}
            <tr>
                <td>{{ h.url }}</td>
                <td>{{ h.status_code or '—' }}</td>
                <td>{{ h.title or '—' }}</td>
                <td>{{ h.ip or '—' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if js_findings %}
    <h2>🔑 JavaScript Findings</h2>
    <table>
        <thead>
            <tr><th>Type</th><th>Value</th><th>Source</th></tr>
        </thead>
        <tbody>
            {% for jf in js_findings %}
            <tr>
                <td><span class="tag">{{ jf.finding_type }}</span></td>
                <td><code>{{ jf.value }}</code></td>
                <td>{{ jf.source_url }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    <div class="footer">
        <p>Generated by ReconX — Attack Surface Intelligence Framework</p>
        <p>This report contains sensitive security information. Handle accordingly.</p>
    </div>
</body>
</html>
